[global]
    font = IosevkaTerm Nerd Font 10
    
    # Charcoal & Silver aesthetic with 80% transparency (CC) for blur
    background = "#0f0f0fCC" 
    foreground = "#e0e0e0"
    frame_color = "#333333"
    highlight = "#a0a0a0"
    
    # Spacing & Geometry
    width = 300
    height = 120
    offset = 15x15
    origin = top-right
    corner_radius = 12
    frame_width = 1
    
    # Better Spacing: Adds a gap between multiple notifications
    gap_size = 10
    
    # Refined internal padding
    padding = 12
    horizontal_padding = 15
    text_icon_padding = 10
    
    # Progress bar for Spotify/Volume (Silver accent)
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

[urgency_normal]
    # Use your silver accent for the border of active alerts
    frame_color = "#a0a0a0"
    timeout = 10
