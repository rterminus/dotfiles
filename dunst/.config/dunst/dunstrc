[global]
    font = IosevkaTerm Nerd Font 10
    # Charcoal & Silver aesthetic
    background = "#0f0f0f"
    foreground = "#e0e0e0"
    frame_color = "#333333"
    highlight = "#a0a0a0"
    
    # Geometry for a "snappy" feel
    width = 300
    height = 120
    offset = 15x15
    corner_radius = 10
    frame_width = 1

[urgency_normal]
    # Use your silver accent for the border of active alerts
    frame_color = "#a0a0a0"
    timeout = 10
