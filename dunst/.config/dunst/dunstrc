[global]
    font = IosevkaTerm Nerd Font 10
    
    background = "#0f0f0fCC" 
    foreground = "#e0e0e0"
    frame_color = "#333333"
    highlight = "#a0a0a0"
    
    separator_height = 2
    separator_color = "#333333"
    
    width = 280            # Slightly thinner for a more "refined" look
    height = 110           # Lowered to match your 22px Waybar aesthetic
    offset = 15x15
    origin = top-right
    corner_radius = 12     # Matches your Waybar bubble radius
    frame_width = 1
    
    gap_size = 10
    
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 10
    
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 280

[urgency_normal]
    # Use silver accent for the border of active alerts
    frame_color = "#a0a0a0"
    timeout = 10
