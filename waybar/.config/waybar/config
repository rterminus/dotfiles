{
    "layer": "top",
    "position": "top",
    "height": 20,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "mpris", "custom/updates", "custom/caffeine"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "custom/gpu", "memory", "disk", "temperature", "pulseaudio", "battery", "tray"],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true
    },

    "custom/caffeine": {
        "format": "<span rise='-1000'>{}</span>",
        "exec": "if pgrep -x hypridle > /dev/null; then echo '󰈈 '; else echo '󰈉 '; fi",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/caffeine.sh",
        "tooltip": true,
        "tooltip-format": "Toggle Hypridle"
    },

    "custom/updates": {
        "format": "󰚰 {}",
        "interval": 3600,
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/updates.sh",
        "on-click": "alacritty -e yay -Syu", 
        "signal": 8
    },

    "mpris": {
        "format": "{player_icon} {title} - {artist}",
        "format-paused": "󰏤 {title} - {artist}",
        "player-icons": { "default": "󰐊", "spotify": "" },
        "status-icons": { "paused": "󰏤" },
        "max-length": 40
    },

    "clock": {
        "interval": 60,
        "format": "󰃭 {:%d/%m   %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "",
        "format-icons": { "default": ["", "", ""] },
        "on-click": "pavucontrol"
    },

    "cpu": { "format": " {usage}%" },

    "custom/gpu": {
        "exec": "cat /sys/class/hwmon/hwmon4/device/gpu_busy_percent",
        "interval": 5,
        "format": "󰢮 {}%",
        "tooltip": false
    },

    "memory": { "format": " {}%" },

    "disk": {
        "interval": 30,
        "format": "󰋊 {percentage_used}%",
        "path": "/"
    },

    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}°C",
        "format-icons": ["", "", ""]
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    "tray": { "icon-size": 15, "spacing": 10 }
}
