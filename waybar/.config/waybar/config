{
    "layer": "top",
    "position": "top",
    "exclusive": false,
    "passthrough": false,
    "height": 22, 
    "margin-top": 8,
    "spacing": 0,

    "modules-left": [],
    "modules-center": [
        "hyprland/workspaces",
        "cpu",
        "memory",
        "custom/caffeine",
        "clock",
        "pulseaudio",
        "battery",
        "network",
        "tray"
    ],
    "modules-right": [],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },

    "clock": {
        "interval": 1,
        "format": "󰃭 {:%d/%m   %H:%M:%S}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<span color='#ffffff'><b>{}</b></span>"
            }
        }
    },

    "network": {
        "format-wifi": "  {essid}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "on-click": "hyprctl dispatch exec \"[float; size 550 450; center] kitty -e nmtui\""
    },

    "cpu": { 
        "format": "󰍛 {usage}%", 
        "interval": 2 
    },
    
    "memory": { 
        "format": "󰘚 {percentage}%", 
        "interval": 2 
    },

    "custom/caffeine": {
        "format": "{}",
        "exec": "if pgrep -x hypridle > /dev/null; then echo '󰈈 '; else echo '󰈉 '; fi",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/caffeine.sh"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": { "default": ["󰕿", "󰖀", "󰕾"] },
        "on-click": "hyprctl dispatch exec \"[float; size 700 400; center] kitty -e pulsemixer\""
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["󰂎", "󰁺", "󰁹"]
    },

    "tray": { 
        "icon-size": 15, 
        "spacing": 10 
    }
}
