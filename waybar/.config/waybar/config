{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "passthrough": false,
    "height": 26,
    "margin-top": 0,
    "spacing": 0,

    "modules-left": [
        "battery",
        "clock",
        "tray",
        "custom/separator",
        "network",
        "pulseaudio",
        "memory",
        "cpu",
        "temperature",
        "custom/caffeine",
        "custom/updates",
    ],
    "modules-center": [
    ],
    "modules-right": [
        "custom/media",
        "custom/separator",
        "hyprland/workspaces",
    ],

    "hyprland/workspaces": {
        "format": "[{name}]",
        "on-click": "activate"
    },

    "custom/media": {
        "format": " {} ",
        "exec": "playerctl metadata --format 'med:{{artist}} - {{title}}' --follow 2>/dev/null",
        "max-length": 45,
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "escape": true
    },

    "custom/updates": {
        "format": "pkg:{}",
        "interval": 3600,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "kitty -e sudo pacman -Syu",
        "signal": 8
    },

    "custom/separator": {
        "format": " │ ",
        "tooltip": false
    },

    "clock": {
        "interval": 1,
        "format": "{:%d/%m  %H:%M:%S}",
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "network": {
        "format-wifi": "net:{essid}",
        "format-ethernet": "net:eth",
        "format-disconnected": "net:dwn",
        "on-click": "hyprctl dispatch exec \"[float; size 550 450; center] kitty -e nmtui\""
    },

    "cpu": { 
        "format": "cpu:{usage}%", 
        "interval": 2 
    },
    
    "memory": {
        "format": "mem:{percentage}%",
        "interval": 2
    },

    "custom/caffeine": {
        "format": "caf:{}",
        "exec": "if pgrep -x hypridle > /dev/null; then echo 'off'; else echo 'on'; fi",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/caffeine.sh"
    },

    "pulseaudio": {
        "format": "vol:{volume}%",
        "format-muted": "vol:mut",
        "on-click": "hyprctl dispatch exec \"[float; size 700 400; center] kitty -e pulsemixer\""
    },

    "battery": {
        "format": "bat:{capacity}%"
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
        "critical-threshold": 80,
        "format": "tmp:{temperatureC}C"
    },
    
    "tray": {
        "icon-size": 14,
        "spacing": 4,
    }
}
